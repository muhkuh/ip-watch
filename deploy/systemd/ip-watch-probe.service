[Unit]
Description=IP Watch Probe Host API Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ipwatch
Group=ipwatch
WorkingDirectory=/opt/ip-watch/probe-host
EnvironmentFile=/etc/ip-watch/probe-host.env
ExecStart=/usr/bin/node src/server.js
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/ip-watch

[Install]
WantedBy=multi-user.target
